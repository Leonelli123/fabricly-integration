{
  "order_number": "{{1.receipt_id}}",
  "currency": "DKK",
  "ordered_at": "{{formatDate(1.create_timestamp; "YYYY-MM-DD")}}",
  "source_name": "Etsy",
  "receiver": {
    "name":         "{{1.name}}",
    "address1":     "{{1.first_line}}",
    "address2":     "{{1.second_line}}",
    "zipcode":      "{{1.zip}}",
    "city":         "{{1.city}}",
    "country_code": "{{1.country_iso}}",
    "email":        "{{1.buyer_email}}"
  },
  "order_lines": [
    {
      "item_name":  "{{2.title}}",
      "quantity":   {{2.quantity}},
      "unit_price": {{2.price}}
    }
  ]
}
